// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Authentication & Authorization ────────────────────────────────────────
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  roleId       String
  role         Role     @relation(fields: [roleId], references: [id])
  status       String   @default("active") // active | suspended | pending
  avatarUrl    String?
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  savedDatasets SavedDataset[]
  auditLogs     AuditLog[]

  @@index([roleId])
  @@index([status])
}

model Role {
  id             String   @id @default(cuid())
  name           String   @unique // English key (admin, manager, accountant, viewer, custom_*)
  nameAr         String   @unique
  description    String?
  // JSON-encoded array of permission strings
  // e.g. ["pnl.view","pnl.upload","prepaid.view","users.manage", ...]
  permissionsJson String  @default("[]")
  isSystem       Boolean  @default(false) // system roles cannot be deleted
  color          String   @default("#6366f1")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  users User[]

  @@index([isSystem])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String   // e.g. "user.create", "role.update", "dataset.delete"
  targetType String?  // e.g. "User", "Role", "SavedDataset"
  targetId   String?
  detailsJson String  @default("{}")
  ipAddress  String?
  userAgent   String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ─── Permanent PnL Storage ────────────────────────────────────────────────
model SavedDataset {
  id          String   @id @default(cuid())
  name        String
  description String?
  companiesJson    String
  journalEntriesJson String
  notesJson   String
  companyCount Int
  periodCount  Int
  datasetCount Int
  ownerId     String?
  owner       User?   @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  isShared    Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([ownerId])
  @@index([createdAt])
}
