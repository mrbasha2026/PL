# Claude AI (Anthropic) API Key
# Get your API key from: https://console.anthropic.com/settings/keys
# You can also set this from the UI in the AI Summary settings panel
ANTHROPIC_API_KEY=your-api-key-here

# Claude Model - Recommended: claude-3-5-sonnet-20241022 (most widely available)
# Options: claude-3-5-sonnet-20241022, claude-sonnet-4-20250514, claude-3-haiku-20240307, claude-opus-4-20250514
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Database
DATABASE_URL=file:/home/z/my-project/db/custom.db
